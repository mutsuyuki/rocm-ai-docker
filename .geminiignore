*.temp
*.swp
*.swo
*.bak
*.orig
*.rej
*.tmp.*
*.backup

# ========================================
# バージョン管理にはあっても、LLMには不要なもの
# （コンテキスト圧迫するだけ＆中身を読んでも意味が薄い）
# ========================================

# ビルド成果物 / バイナリ
bin/
obj/
out/
build/
dist/
target/
release/
debug/
Debug/
Release/

*.exe
*.dll
*.so
*.dylib
*.lib
*.a
*.o
*.obj
*.pdb

# アーカイブ
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# パッケージロック類（必要なら外してOK）
package-lock.json
yarn.lock
pnpm-lock.yaml
# ※依存関係が重要なら上記はコメントアウトしてもよい

